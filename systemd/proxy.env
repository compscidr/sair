# /etc/sair/proxy.env
# Environment variables for sair-proxy

# Orchestrator connection (lock management only)
ORCHESTRATOR_ADDR=orchestrator.sair.run:9090
ORCHESTRATOR_TLS=true

# Device source connection (local, for ADB operations)
DEVICE_SOURCE_ADDR=localhost:8080

# Authentication
# WARNING: Set this to a real secret value before starting sair-proxy.
SAIR_API_KEY=CHANGEME

# Proxy ports
ADB_PROXY_PORT=5037
PROXY_HTTP_PORT=8550
PROXY_HTTP_HOST=0.0.0.0

# Lock heartbeat
HEARTBEAT_INTERVAL_SECONDS=60
