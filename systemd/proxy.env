# /etc/sair/proxy.env
# Environment variables for sair-proxy

# Orchestrator connection
ORCHESTRATOR_ADDR=localhost:9090
ORCHESTRATOR_TLS=false

# Authentication
SAIR_API_KEY=dev-key-123

# Proxy ports
ADB_PROXY_PORT=5037
PROXY_HTTP_PORT=8550
PROXY_HTTP_HOST=0.0.0.0

# Session management
SESSION_GRACE_PERIOD_MS=30000
HEARTBEAT_INTERVAL_SECONDS=60
